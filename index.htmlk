<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Habit Crowd</title>

<style>
body {
  margin:0;
  font-family: Arial;
  background: linear-gradient(to bottom, #1a1a2e, #16213e);
  color:white;
  text-align:center;
}

.screen {
  display:none;
  padding:20px;
}

.active {
  display:block;
}

button {
  padding:12px;
  margin:10px;
  border:none;
  border-radius:10px;
  background:#ff7b54;
  color:white;
  font-size:16px;
}

.character {
  background:#222;
  margin:10px;
  padding:15px;
  border-radius:15px;
  animation: float 2s infinite alternate;
}

@keyframes float {
  from {transform: translateY(0);}
  to {transform: translateY(-10px);}
}
</style>
</head>

<body>

<!-- HOME -->
<div id="home" class="screen active">
  <h1>✨ Habit Crowd</h1>
  <p>Virtual Anime Group That Pushes You</p>

  <button onclick="startHabit()">Start Habit</button>
</div>

<!-- HABIT SCREEN -->
<div id="habit" class="screen">
  <h2>🔥 Your Habit World</h2>
  <p id="habitText"></p>

  <div class="character">👦 "Come on, let's focus!"</div>
  <div class="character">👧 "Everyone is working, don't stop!"</div>
  <div class="character">🧑 "Stay consistent, you can do it!"</div>

  <button onclick="completeTask()">✅ Complete Task</button>
</div>

<!-- SUCCESS -->
<div id="success" class="screen">
  <h2>🎉 Amazing!</h2>

  <div class="character">👏 "Great Job!"</div>
  <div class="character">🎊 "We are proud of you!"</div>
  <div class="character">🔥 "Keep going!"</div>

  <button onclick="goHome()">Back</button>
</div>

<script>
let habit = "";

function show(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

function startHabit(){
  habit = prompt("Enter your habit (Study / Exercise / English etc)");
  if(habit){
    document.getElementById("habitText").innerText = "You are doing: " + habit;
    show("habit");
  }
}

function completeTask(){
  show("success");
}

function goHome(){
  show("home");
}
</script>

</body>
</html>
